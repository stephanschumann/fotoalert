# =============================================================================
# FotoAlert – .gitignore
# =============================================================================

# Nutzer-Daten — nie in Git (Source of Truth ist der Prod-Server)
backend/data/fotoalert.db
backend/data/fotoalert.db-shm
backend/data/fotoalert.db-wal
backend/data_dev/

# Automatische DB-Snapshots vor jedem Precompute-Lauf (TASK-56)
backend/data/snapshots/

# Nutzer-Uploads (Beispielbilder, US-120) — Server-Daten, keine Code-Assets
backend/data/location_images/

# FUSE-Reste (entstehen bei gleichzeitigem Datei-Zugriff über den gemounteten
# Cowork-Ordner, z.B. während paralleler Server-/Precompute-Läufe)
backend/data/.fuse_hidden*

# Kanban-Sync-Zwischenordner (tools/sync_kanban.py)
tools/_kanban_out/
tools/_kanban_tmp/

# Python-Artefakte
__pycache__/
*.py[cod]
*.pyo

# macOS
.DS_Store

# Virtuelle Umgebungen
venv/
.venv/
env/

# Secrets — NIE in Git (US-66: Login-Passwörter, Auth-Secret)
.env
*.env
!.env.example

# Editor
.idea/
.vscode/
*.swp
