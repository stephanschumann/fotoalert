# FotoAlert Backend – Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein.

# Apple Push Notification Service (APNs)
# Alle Werte findest du unter: developer.apple.com → Certificates, Identifiers & Profiles
APNS_KEY_ID=XXXXXXXXXX           # 10-stellige Key-ID (z.B. ABC1234567)
APNS_TEAM_ID=XXXXXXXXXX          # 10-stellige Team-ID (z.B. XYZ9876543)
APNS_KEY_PATH=/path/to/AuthKey_XXXXXXXXXX.p8  # Pfad zur heruntergeladenen .p8 Datei
APNS_BUNDLE_ID=de.fotoalert.app  # Bundle-ID deiner iOS-App (aus Xcode)
APNS_PRODUCTION=false             # false = Sandbox (Testgeräte), true = Production (App Store)
