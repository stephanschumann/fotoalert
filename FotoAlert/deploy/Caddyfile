# FotoAlert – Caddy Reverse Proxy mit automatischem HTTPS
# Let's Encrypt Zertifikat wird automatisch ausgestellt und erneuert.
# Voraussetzung: DNS-Eintrag (A-Record) zeigt bereits auf diesen Server.

YOUR_DOMAIN {
    # HTTPS-Proxy zu FastAPI
    reverse_proxy localhost:8000 {
        # Timeout für lange Precompute-Anfragen
        transport http {
            read_timeout 120s
        }
    }

    # Sicherheits-Header
    header {
        X-Content-Type-Options nosniff
        X-Frame-Options DENY
        Referrer-Policy strict-origin-when-cross-origin
        # HSTS: Browser merkt sich HTTPS für 1 Jahr
        Strict-Transport-Security "max-age=31536000"
        # Service Worker darf nur von dieser Origin laden
        -Server
        # Content-Security-Policy (TASK-82): eigene Seite, die zwei Bibliotheks-CDNs
        # (Leaflet via cdnjs, astronomy-engine via jsdelivr) sowie die drei
        # Kartenkachel-Anbieter (OSM, ArcGIS, CartoCDN – jeweils inkl. genutzter
        # Unterdomains) sind erlaubt. Eingebetteter Code (Script/Style) bleibt
        # bewusst über 'unsafe-inline' zugelassen, da die komplette App aus
        # eingebettetem Code besteht (siehe Ticket-Annahme, keine Nachlässigkeit).
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com; img-src 'self' https://tile.openstreetmap.org https://*.tile.openstreetmap.org https://server.arcgisonline.com https://basemaps.cartocdn.com https://*.basemaps.cartocdn.com"
        # Permissions-Policy (TASK-82): alles sperren außer Standortabfrage (GPS-Knopf)
        # und Zwischenablage-Zugriff (Koordinaten aus Zwischenablage einfügen).
        Permissions-Policy "accelerometer=(), ambient-light-sensor=(), autoplay=(), battery=(), camera=(), display-capture=(), document-domain=(), encrypted-media=(), fullscreen=(), gamepad=(), geolocation=(self), gyroscope=(), magnetometer=(), microphone=(), midi=(), payment=(), picture-in-picture=(), publickey-credentials-get=(), screen-wake-lock=(), sync-xhr=(), usb=(), web-share=(), xr-spatial-tracking=(), clipboard-read=(self), clipboard-write=(self)"
    }

    # Logs
    log {
        output file /var/log/caddy/fotoalert.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}
